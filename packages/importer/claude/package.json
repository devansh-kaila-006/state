{
  "name": "@state/importer-claude",
  "version": "0.1.0",
  "description": "Claude Code importer for .agent files",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "claude",
    "importer",
    "agent",
    "anthropic"
  ],
  "author": "State Project Contributors",
  "license": "MIT",
  "dependencies": {
    "@state/format": "workspace:*",
    "node-fetch": "^2.7.0",
    "readline-sync": "^1.4.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-fetch": "^2.6.4",
    "@types/readline-sync": "^1.4.4",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
